<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Network Test"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <Button
        android:id="@+id/btn_normal_request"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Normal Network Request Test"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_stream_upload"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Streaming Upload Test"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_stream_download"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Streaming Download Test" />

</LinearLayout>

